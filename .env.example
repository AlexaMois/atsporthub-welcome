# ===========================================================================
# АТС Портал — шаблон переменных окружения
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env в git!
# ===========================================================================

# ---------------------------------------------------------------------------
# Supabase (фронтенд)
# Значения берутся из: https://supabase.com/dashboard -> Settings -> API
# ---------------------------------------------------------------------------

# ID вашего Supabase-проекта (часть URL: <project_id>.supabase.co)
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id

# Публичный anon-ключ (безопасен для фронтенда)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Полный URL проекта Supabase
VITE_SUPABASE_URL=https://your_supabase_project_id.supabase.co

# ---------------------------------------------------------------------------
# Bpium (только для Edge Function — не попадает на фронтенд!)
# Хранится в Supabase Secrets: Dashboard -> Edge Functions -> Secrets
# ---------------------------------------------------------------------------

# BPIUM_LOGIN=your_bpium_login
# BPIUM_PASSWORD=your_bpium_password
